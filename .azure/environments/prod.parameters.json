{
    "schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "location": {
            "value": "eastus"
        },
        "environment": {
            "value": "prod"
        },
        "functionAppName": {
            "value": "aria-prod"
        },
        "storageAccountName": {
            "value": "ariaprodstorage"
        },
        "sqlServerName": {
            "value": "aria-prod-sql"
        },
        "sqlAdminUsername": {
            "value": "sqladmin"
        },
        "sqlAdminPassword": {
            "value": null
        },
        "cosmosAccountName": {
            "value": "aria-prod-cosmos"
        },
        "enableCosmos": {
            "value": true
        },
        "containerRegistryName": {
            "value": "ariaprod"
        },
        "functionImageUri": {
            "value": "ariaprod.azurecr.io/functions:latest"
        },
        "appInsightsName": {
            "value": "aria-prod-insights"
        },
        "keyVaultName": {
            "value": "aria-prod-kv"
        },
        "tags": {
            "value": {
                "environment": "prod",
                "platform": "aria",
                "team": "platform",
                "costCenter": "engineering"
            }
        }
    }
}