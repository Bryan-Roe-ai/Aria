{
    "$schema": "https://github.com/Azure/data-api-builder/releases/latest/download/dab.draft.schema.json",
    "data-source": {
        "database-type": "mssql",
        "connection-string": "@env('DAB_CONNECTION_STRING')"
    },
    "runtime": {
        "rest": {
            "enabled": true,
            "path": "/api"
        },
        "graphql": {
            "enabled": true,
            "path": "/graphql"
        },
        "mcp": {
            "enabled": false
        },
        "host": {
            "mode": "production",
            "cors": {
                "origins": [
                    "https://aria.example.com",
                    "http://localhost:3000",
                    "http://localhost:8080"
                ]
            }
        }
    },
    "entities": {
        "OrchestratorJobs": {
            "source": {
                "type": "table",
                "object": "dbo.OrchestratorJobs",
                "key-fields": ["OrchestratorJobId"]
            },
            "permissions": [
                {
                    "role": "anonymous",
                    "actions": ["read"]
                },
                {
                    "role": "authenticated",
                    "actions": ["create", "read", "update"]
                },
                {
                    "role": "admin",
                    "actions": ["delete"]
                }
            ]
        }
    }
}
