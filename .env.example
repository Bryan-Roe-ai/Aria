# Example environment variables for local development.
# Copy to .env or use local.settings.json for Azure Functions and fill in your keys.

# Azure Speech (for /api/tts)
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=

# Azure/OpenAI or OpenAI keys (optional)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
OPENAI_API_KEY=

# Local AI providers (optional)
# LM Studio default server URL is http://127.0.0.1:1234/v1
# In dev containers, host LM Studio is often reachable via http://host.docker.internal:1234/v1
LMSTUDIO_BASE_URL=
LMSTUDIO_MODEL=local-model

# Ollama default OpenAI-compatible URL is http://127.0.0.1:11434/v1
OLLAMA_BASE_URL=
OLLAMA_MODEL=llama3.2

# Default provider routing (auto|ollama|lmstudio|local|azure|openai)
DEFAULT_AI_PROVIDER=auto
ARIA_LLM_PROVIDER=

# Allow a local TTS fallback on the server when AZURE_SPEECH_KEY/REGION are not set
# Set to 'true' to enable (requires installing pyttsx3 or gTTS in the functions environment)
QAI_ENABLE_LOCAL_TTS=true
