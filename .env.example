# Example environment variables for local development.
# Copy to .env or use local.settings.json for Azure Functions and fill in your keys.

# Azure Speech (for /api/tts)
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=

# Azure/OpenAI or OpenAI keys (optional)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
OPENAI_API_KEY=

# Allow a local TTS fallback on the server when AZURE_SPEECH_KEY/REGION are not set
# Set to 'true' to enable (requires installing pyttsx3 or gTTS in the functions environment)
QAI_ENABLE_LOCAL_TTS=true

# AGI provider base. When using `--provider agi`, this pins the underlying chat
# provider that AGI wraps. Defaults to "auto" (LM Studio → Ollama → Azure →
# OpenAI → local echo). For a guaranteed-working, dependency-free deterministic
# base in minimal environments (no GPU / no API keys / no pulled Ollama model),
# use "local_echo". Note: "local" prefers local *runtimes* (LM Studio, then
# Ollama) and only degrades to echo if none are reachable. Other values: azure,
# openai, lmstudio, ollama.
AGI_BASE_PROVIDER=auto
