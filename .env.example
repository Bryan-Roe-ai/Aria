# Example environment variables for local development.
# Copy to .env or use local.settings.json for Azure Functions and fill in your keys.

# Azure Speech (for /api/tts)
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=

# Azure/OpenAI or OpenAI keys (optional)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
OPENAI_API_KEY=

# Data API Builder (DAB) / Azure SQL
# Preferred auth in production/local: Entra / Managed Identity (Active Directory Default)
DAB_CONNECTION_STRING=Server=tcp:aria-24563.database.windows.net,1433;Initial Catalog=Aria;Authentication=Active Directory Default;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;
# SQL auth fallback (only when Entra/managed identity is unavailable):
# DAB_CONNECTION_STRING=Server=tcp:aria-24563.database.windows.net,1433;Initial Catalog=Aria;User ID=<SQL_USERNAME>;Password=<SQL_PASSWORD>;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;

# Local AI providers (optional)
# LM Studio default server URL is http://127.0.0.1:1234/v1
# In dev containers, host LM Studio is often reachable via http://host.docker.internal:1234/v1
LMSTUDIO_BASE_URL=
LMSTUDIO_MODEL=local-model

# Ollama default OpenAI-compatible URL is http://127.0.0.1:11434/v1
OLLAMA_BASE_URL=
OLLAMA_MODEL=llama3.2

# Default provider routing (auto|ollama|lmstudio|local|azure|openai)
DEFAULT_AI_PROVIDER=auto
ARIA_LLM_PROVIDER=

# Allow a local TTS fallback on the server when AZURE_SPEECH_KEY/REGION are not set
# Set to 'true' to enable (requires installing pyttsx3 or gTTS in the functions environment)
QAI_ENABLE_LOCAL_TTS=true

# AGI provider base. When using `--provider agi`, this pins the underlying chat
# provider that AGI wraps. Defaults to "auto" (LM Studio → Ollama → Azure →
# OpenAI → local echo). For a guaranteed-working, dependency-free deterministic
# base in minimal environments (no GPU / no API keys / no pulled Ollama model),
# use "local_echo". Note: "local" prefers local *runtimes* (LM Studio, then
# Ollama) and only degrades to echo if none are reachable. Other values: azure,
# openai, lmstudio, ollama.
AGI_BASE_PROVIDER=auto
