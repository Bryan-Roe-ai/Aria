# Local environment variables (developer-local only).
# Keep this file untracked and do NOT store real secrets in source control.
# Reference template: .env.example
# Recommended local hardening: chmod 600 .env

# Azure Speech (for /api/tts)
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=

# Azure/OpenAI or OpenAI keys (optional)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
OPENAI_API_KEY=

# Optional Azure ML settings (used by Azure ML workflows/scripts)
AZURE_ML_SUBSCRIPTION_ID=
AZURE_ML_RESOURCE_GROUP=
AZURE_ML_WORKSPACE=

# Allow local TTS fallback when Azure Speech key/region are not set.
# Set to 'true' for local development only.
QAI_ENABLE_LOCAL_TTS=true
