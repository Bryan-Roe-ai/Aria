# =============================================================================
# Aria — Environment Configuration
# =============================================================================
# This file contains environment variables for local development.
#
# SECURITY WARNING:
#   - NEVER commit real secrets, API keys, or credentials to version control.
#   - Ensure `.env` is listed in `.gitignore`.
#   - Use `.env.example` as the committed template; keep `.env` local only.
#   - For production, use Azure Key Vault, GitHub Secrets, or a secrets manager.
#
# Format rules:
#   - KEY=VALUE (no spaces around `=`)
#   - Quote values containing spaces or special chars: KEY="my value"
#   - Use `__REPLACE__` as a placeholder for required values
#   - Lines starting with `#` are comments
# =============================================================================


# -----------------------------------------------------------------------------
# Azure Machine Learning Workspace
# -----------------------------------------------------------------------------
# Required for quantum ML pipelines and model training/deployment.
# Find these values in the Azure Portal under your ML workspace overview.
AZURE_ML_SUBSCRIPTION_ID=__REPLACE__
AZURE_ML_RESOURCE_GROUP=__REPLACE__
AZURE_ML_WORKSPACE=__REPLACE__
AZURE_ML_REGION=eastus
AZURE_ML_TENANT_ID=__REPLACE__


# -----------------------------------------------------------------------------
# Azure OpenAI (Primary Chat Provider)
# -----------------------------------------------------------------------------
AZURE_OPENAI_ENDPOINT=__REPLACE__
AZURE_OPENAI_API_KEY=__REPLACE__
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small


# -----------------------------------------------------------------------------
# OpenAI (Fallback Provider)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=__REPLACE__
OPENAI_MODEL=gpt-4o-mini
OPENAI_ORG_ID=


# -----------------------------------------------------------------------------
# LMStudio / Local Models (Fallback Chain)
# -----------------------------------------------------------------------------
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_MODEL=local-model
LOCAL_MODEL_PATH=./AI/microsoft_phi-silica-3.6_v1/models
LORA_ADAPTER_PATH=./AI/microsoft_phi-silica-3.6_v1/adapters


# -----------------------------------------------------------------------------
# Provider Fallback Chain
# -----------------------------------------------------------------------------
# Comma-separated, ordered by preference. First available is used.
CHAT_PROVIDER_CHAIN=azure_openai,openai,lmstudio,local


# -----------------------------------------------------------------------------
# Azure Speech Services (TTS)
# -----------------------------------------------------------------------------
AZURE_SPEECH_KEY=__REPLACE__
AZURE_SPEECH_REGION=eastus
AZURE_SPEECH_VOICE=en-US-JennyNeural
TTS_LOCAL_FALLBACK=true


# -----------------------------------------------------------------------------
# Azure Cosmos DB (Conversation & State Persistence)
# -----------------------------------------------------------------------------
COSMOS_ENDPOINT=__REPLACE__
COSMOS_KEY=__REPLACE__
COSMOS_DATABASE=aria
COSMOS_CONTAINER_CONVERSATIONS=conversations
COSMOS_CONTAINER_STATE=aria_state


# -----------------------------------------------------------------------------
# Database (SQL / Postgres for telemetry & training history)
# -----------------------------------------------------------------------------
DATABASE_URL=sqlite:///./data_out/aria.db
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30


# -----------------------------------------------------------------------------
# Quantum Computing Backend
# -----------------------------------------------------------------------------
QUANTUM_BACKEND=simulator
QUANTUM_NUM_QUBITS=8
QUANTUM_SHOTS=1024
QUANTUM_FALLBACK_CLASSICAL=true
AZURE_QUANTUM_WORKSPACE=__REPLACE__
AZURE_QUANTUM_LOCATION=eastus


# -----------------------------------------------------------------------------
# Aria Web Server (apps/aria)
# -----------------------------------------------------------------------------
ARIA_HOST=0.0.0.0
ARIA_PORT=8080
ARIA_DEBUG=false
ARIA_CORS_ORIGINS=http://localhost:8080,http://localhost:3000


# -----------------------------------------------------------------------------
# Azure Functions (function_app.py)
# -----------------------------------------------------------------------------
FUNCTIONS_WORKER_RUNTIME=python
AzureWebJobsStorage=__REPLACE__
FUNCTIONS_HOST_PORT=7071


# -----------------------------------------------------------------------------
# Autonomous Training Orchestrator
# -----------------------------------------------------------------------------
AUTO_TRAINING_ENABLED=true
AUTO_TRAINING_INTERVAL_MINUTES=30
AUTO_TRAINING_MIN_ACCURACY=0.85
AUTO_TRAINING_PROMOTE_THRESHOLD=0.90
AUTO_TRAINING_DEGRADATION_ALERT=0.05
AUTO_TRAINING_LOG_PATH=./data_out/autonomous_training.log


# -----------------------------------------------------------------------------
# Telemetry & Observability
# -----------------------------------------------------------------------------
APPLICATIONINSIGHTS_CONNECTION_STRING=__REPLACE__
LOG_LEVEL=INFO
TELEMETRY_ENABLED=true
OTEL_SERVICE_NAME=aria


# -----------------------------------------------------------------------------
# Security & Auth
# -----------------------------------------------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=__REPLACE__
JWT_SECRET=__REPLACE__
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60


# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
FEATURE_QUANTUM_LLM=true
FEATURE_AUTO_EXECUTE=true
FEATURE_WORLD_GENERATION=true
FEATURE_EYE_TRACKING=true
FEATURE_LORA_ADAPTERS=true


# -----------------------------------------------------------------------------
# Development Only
# -----------------------------------------------------------------------------
ENVIRONMENT=development
DEBUG=false
PYTHONUNBUFFERED=1
